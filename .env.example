# Dados de contato exibidos no site (ver content/site.ts para edição direta)
NEXT_PUBLIC_SITE_URL=https://protocolometamorfose.com.br

# Integração de pagamento Pix (produção)
# Exemplo usando Mercado Pago - substitua pelo provedor escolhido
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Modo de desenvolvimento: quando "true", o checkout simula a confirmação
# do Pix por um botão em vez de aguardar o webhook real do provedor.
NEXT_PUBLIC_PIX_DEV_MODE=true

# E-mail para envio de notificações (formulário de contato / confirmação de compra)
EMAIL_FROM=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
